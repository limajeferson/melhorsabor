# ============================================================
# .env.example — MelhorSabor
# NUNCA commitar o .env real — apenas este template
# ============================================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend (Supabase públicas)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Afiliados
AMAZON_AFFILIATE_TAG=
ML_AFFILIATE_ID=

# Analytics / APM
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=                      # PostHog project API key (free tier). Vazio = analytics desligado
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # use https://eu.i.posthog.com para região EU (melhor p/ LGPD)

# Sentry (error monitoring — free tier)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                 # apenas para source maps (CI)

# Mercado Pago (Checkout Pro)
# Obter em: https://www.mercadopago.com.br/developers/panel
# Sandbox: credenciais de teste começam com "TEST-"
# Produção: credenciais começam com "APP_USR-"
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx   # token privado (server-side only — não usar NEXT_PUBLIC_)

# App
NODE_ENV=development
DEBUG=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
